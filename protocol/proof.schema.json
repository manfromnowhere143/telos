{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/manfromnowhere143/telos/protocol/proof.schema.json",
  "title": "Telos Proof Receipt",
  "type": "object",
  "required": [
    "receipt_id",
    "task_id",
    "agent_id",
    "benchmark_id",
    "status",
    "stated_goal",
    "acceptance_criteria",
    "evidence",
    "falsifiers",
    "sha256"
  ],
  "additionalProperties": false,
  "properties": {
    "receipt_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "benchmark_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "blocked", "not_applicable"]
    },
    "stated_goal": { "type": "string", "minLength": 1 },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "status"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "test",
              "typecheck",
              "build",
              "diff_scope",
              "live_check",
              "artifact",
              "adversarial_review"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "blocked", "not_applicable"]
          },
          "artifact": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "falsifiers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
