{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Telos Target Survey Scorecard",
  "type": "object",
  "required": ["generated_at", "candidates", "decision"],
  "additionalProperties": false,
  "properties": {
    "generated_at": { "type": "string" },
    "decision": {
      "type": "string",
      "enum": ["TARGET_SELECTED", "HYBRID_OVERLAY_SELECTED", "SURVEY_NULL", "BLOCKED"]
    },
    "candidates": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "frontier_relevance",
          "public_baseline_quality",
          "falsifiability",
          "evidence_surface",
          "aweb_fit",
          "saturation_risk",
          "operational_cost",
          "rationale",
          "sources"
        ],
        "additionalProperties": false,
        "properties": {
          "candidate_id": { "type": "string" },
          "frontier_relevance": { "type": "integer", "minimum": 0, "maximum": 5 },
          "public_baseline_quality": { "type": "integer", "minimum": 0, "maximum": 5 },
          "falsifiability": { "type": "integer", "minimum": 0, "maximum": 5 },
          "evidence_surface": { "type": "integer", "minimum": 0, "maximum": 5 },
          "aweb_fit": { "type": "integer", "minimum": 0, "maximum": 5 },
          "saturation_risk": { "type": "integer", "minimum": 0, "maximum": 5 },
          "operational_cost": { "type": "integer", "minimum": 0, "maximum": 5 },
          "rationale": { "type": "string", "minLength": 1 },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "format": "uri" }
          }
        }
      }
    }
  }
}
