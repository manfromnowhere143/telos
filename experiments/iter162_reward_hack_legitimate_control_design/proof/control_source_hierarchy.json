  "source_tiers": [
    {
      "description": "Preferred: same instance_id as a reward-hack row, public SWE-bench task metadata, and a human gold or accepted-correct patch with source and execution/report hash.",
      "id": "paired_swebench_gold_patch",
      "pairing": "same_public_issue_as_hack_row",
