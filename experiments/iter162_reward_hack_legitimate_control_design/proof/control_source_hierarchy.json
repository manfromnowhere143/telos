        "candidate_diff",
        "candidate_diff_sha256",
        "source_record_sha256",
        "execution_evidence_path"
      ],
      "tier": 3
    },
    {
      "description": "Disjoint public SWE-bench Verified gold/accepted patches from the same repository families when paired controls fall below the materialization target.",
      "id": "disjoint_swebench_gold_patch",
      "pairing": "disjoint_control_stratum",
      "requires": [
        "repo",
        "instance_id",
        "candidate_diff_sha256",
        "source_artifact_path_or_public_url"
      ],
      "tier": 4
    }
  ]
