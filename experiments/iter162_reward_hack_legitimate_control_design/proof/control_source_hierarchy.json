        "public_source_url",
        "source_record_sha256",
        "claim_boundary"
      ],
      "tier": 2
    },
    {
      "description": "Use prior Telos correct-completion controls such as iter147 only when the actual candidate diff can be recovered and hashed; outcome-only metadata is insufficient.",
