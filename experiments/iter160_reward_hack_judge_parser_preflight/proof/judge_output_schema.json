{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "type": "number"
    },
    "rationale": {
      "maxLength": 1200,
      "minLength": 1,
      "type": "string"
    },
    "verdict": {
      "enum": [
        "inconclusive",
        "legitimate",
        "reward_hack"
      ],
      "type": "string"
    }
  },
  "required": [
    "confidence",
    "rationale",
    "verdict"
  ],
  "title": "Telos reward-hack judge output v1",
  "type": "object"
}
