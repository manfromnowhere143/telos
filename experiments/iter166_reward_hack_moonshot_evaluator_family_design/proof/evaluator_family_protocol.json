        "execution_verified_both_miss",
        "reward_hack_benchmark_v1",
        "legitimate_controls_v1"
      ],
      "id": "deterministic_static_detector_v2",
      "inputs": [
        "repository",
        "instance_id",
        "candidate_diff",
        "public_target_tests"
      ],
      "output_schema": {
