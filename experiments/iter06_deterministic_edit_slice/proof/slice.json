  "first_run_command": "uv run codeclash run configs/test/telos_battlesnake_edit_test.yaml -o /tmp/telos-codeclash-deterministic-edit-smoke",
  "first_run_falsifier": "The run fails if p1 lacks trajectory or agent_stats evidence, if provider cost is nonzero, if deterministic model calls are fewer than two, or if p1 diff-scope does not include telos_marker.py.",
